CREATE VIEW ChurnRiskLevel AS
SELECT 
    CustomerId, 
    Country, 
    AgeGroup, 
    CreditScoreCat, 
    TenureCat, 
    ProduceCat,
    CASE
        WHEN CreditScoreCat IN ('Poor', 'Fair')
             AND BalanceCat = 'Very Low'
             AND ProduceCat = 'Low Engagement'
             AND TenureCat = 'New'
            THEN 'High Risk'

        WHEN (CreditScoreCat IN ('Poor', 'Fair') AND BalanceCat = 'Very Low')
          OR (CreditScoreCat IN ('Poor', 'Fair') AND ProduceCat = 'Low Engagement')
          OR (BalanceCat IN ('Very Low', 'Low') AND ProduceCat = 'Low Engagement')
            THEN 'Elevated Risk'

        WHEN ProduceCat = 'Moderate Engagement'
          OR TenureCat = 'Established'
            THEN 'Medium Risk'

        ELSE 'Low Risk'
    END AS ChurnRisk
FROM CustomerDetails;

(SELECT
    c.ChurnRisk,
    COUNT(*) AS TotalCustomers,
    SUM(cd.ChurnFlag) AS ChurnedCustomers,
    CAST(SUM(cd.ChurnFlag) AS FLOAT) / COUNT(*) AS ChurnRate
FROM ChurnRiskLevel AS c
LEFT JOIN CustomerDetails AS cd
    ON c.CustomerId = cd.CustomerId
GROUP BY c.ChurnRisk
ORDER BY ChurnRate DESC;)


